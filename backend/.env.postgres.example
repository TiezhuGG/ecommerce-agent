APP_NAME=Ecommerce Agent API
APP_ENV=development
FRONTEND_ORIGIN=http://127.0.0.1:5173

# 本地 PostgreSQL 联调示例。
# 先运行根目录下的 docker-compose.postgres-local.yml，再把这份文件内容复制到 backend/.env。
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/ecommerce_agent

ADMIN_ACCESS_CODE=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_API_STYLE=auto
