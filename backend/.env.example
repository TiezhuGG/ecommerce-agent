APP_NAME=Ecommerce Agent API
APP_ENV=development
FRONTEND_ORIGIN=http://127.0.0.1:5173
# 本地开发默认建议继续使用 SQLite，零依赖、可直接落地到 backend/.tmp。
DATABASE_URL=sqlite:///./.tmp/ecommerce-agent-dev.db
# 上线前再切 PostgreSQL，例如:
# DATABASE_URL=postgresql+psycopg://postgres:password@127.0.0.1:5432/ecommerce_agent
ADMIN_ACCESS_CODE=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_API_STYLE=auto
